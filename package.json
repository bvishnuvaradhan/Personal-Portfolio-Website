{
  "name": "personal-portfolio-monorepo",
  "version": "1.0.0",
  "description": "Full Stack Personal Portfolio with Admin Dashboard, Analytics, Blog and secure Auth",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --prefix frontend",
    "prisma:generate": "npm run prisma:generate --prefix backend",
    "prisma:migrate": "npm run prisma:migrate --prefix backend",
    "prisma:seed": "npm run prisma:seed --prefix backend"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
